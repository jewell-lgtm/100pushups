# Copy to .env (or .env.local) and fill in. Never commit a real secret.

# Bearer auth (Phase 1.5). Production refuses to boot without both.
AUTH_SECRET=dev-auth-secret-change-me
REGISTER_API_KEY=dev-register-key-change-me

# Ollama transport. Backend talks to Ollama on the same host via OrbStack's
# internal network — see "Ollama transport" in the root README. host.docker.internal
# is the safe portable default; switch to the OrbStack `.local` name once you've
# confirmed it from inside the pod (`kubectl exec ... curl $OLLAMA_URL/api/tags`).
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

# Optional: only set if Ollama ever moves off-box and you need basic auth on
# that hop. Backend skips the Authorization header when these are unset.
# OLLAMA_USER=
# OLLAMA_PASSWORD=

PORT=3000
NODE_ENV=development
